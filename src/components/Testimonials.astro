---
const testimonials = [
  {
    name: "Roberto y Karla",
    text: "Vengo con mi esposa. Ella se hace el color y yo el corte. Salimos los dos contentos. Es súper práctico encontrar un lugar así.",
    stars: 5,
    initials: "RK",
    bg: "bg-primary-dark",
    textCol: "text-white"
  },
  {
    name: "Miguel A.",
    text: "El mejor corte que me han hecho en Guadalajara. El trato es excelente y el lugar tiene muy buena vibra.",
    stars: 5,
    initials: "M",
    bg: "bg-gray-100",
    textCol: "text-primary-dark"
  },
  {
    name: "Sofía T.",
    text: "Me encanta que puedo traer a toda la familia. La atención es impecable y siempre salgo encantada con mi peinado.",
    stars: 4,
    initials: "S",
    bg: "bg-primary-light",
    textCol: "text-primary-dark"
  }
];

const renderStars = (count: number) => {
  return Array(5).fill(0).map((_, i) => (
    `<svg class="w-5 h-5 ${i < count ? 'text-accent-gold' : 'text-gray-300'}" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>`
  )).join('');
};
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">Lo que dicen nuestros clientes</h2>
      <p class="text-gray-600 text-lg">Más de 150 reseñas en Google respaldan nuestro trabajo.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map(testimonial => (
        <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 hover:shadow-lg transition-shadow duration-300">
          <div class="flex items-center space-x-4 mb-6">
            <div class={`w-12 h-12 rounded-full flex items-center justify-center font-bold text-lg ${testimonial.bg} ${testimonial.textCol}`}>
              {testimonial.initials}
            </div>
            <div>
              <h4 class="font-bold text-gray-900">{testimonial.name}</h4>
              <div class="flex" set:html={renderStars(testimonial.stars)} />
            </div>
          </div>
          <p class="text-gray-600 italic">"{testimonial.text}"</p>
        </div>
      ))}
    </div>
  </div>
</section>
