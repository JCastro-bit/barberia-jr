---
const reasons = [
  {
    title: "Unisex de verdad",
    description: "Todos son bienvenidos. Un espacio diseñado para que hombres y mujeres se sientan cómodos y bien atendidos.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-dark"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  },
  {
    title: "Casi 5 estrellas",
    description: "Más de 150 clientes nos respaldan con una calificación de 4.8 estrellas en Google. Tu satisfacción es nuestra prioridad.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-gold"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
  },
  {
    title: "Ubicación céntrica",
    description: "Nos encontramos en el corazón de Guadalajara, con fácil acceso y un ambiente relajante ideal para tu visita.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-dark"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`
  }
];
---

<section class="py-20 bg-gray-50 border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">¿Por qué elegir Barbería JR?</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {reasons.map(reason => (
        <div class="bg-white p-8 rounded-3xl shadow-sm hover:shadow-md transition-shadow duration-300">
          <div class="w-14 h-14 bg-gray-50 rounded-2xl flex items-center justify-center mb-6" set:html={reason.icon} />
          <h3 class="text-xl font-bold text-gray-900 mb-3">{reason.title}</h3>
          <p class="text-gray-600 leading-relaxed">{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
