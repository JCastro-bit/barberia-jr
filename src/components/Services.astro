---
const servicesHim = [
  { name: "Corte Clásico", description: "Corte con tijera o máquina, incluye lavado y peinado." },
  { name: "Diseño de Barba", description: "Alineación, recorte y perfilado con toalla caliente." },
  { name: "Afeitado", description: "Afeitado tradicional al ras para un acabado impecable." },
  { name: "Coloración Masculina", description: "Cobertura de canas o cambios de estilo sutiles." },
];

const servicesHer = [
  { name: "Corte y Estilizado", description: "Diseño de imagen personalizado a tus facciones." },
  { name: "Coloración", description: "Tintes, balayage, luces y técnicas en tendencia." },
  { name: "Tratamiento Capilar", description: "Hidratación profunda, keratina y reparación." },
  { name: "Peinado para Eventos", description: "Ondas, alaciados y recogidos para ocasiones especiales." },
];
---

<section id="servicios" class="py-24 bg-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">Nuestros Servicios</h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        Experiencia y dedicación para resaltar la mejor versión de ti, sin importar tu género.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-24 relative">
      <!-- Divider -->
      <div class="hidden md:block absolute top-0 bottom-0 left-1/2 w-px bg-gradient-to-b from-transparent via-gray-200 to-transparent -translate-x-1/2"></div>

      <!-- Him Column -->
      <div class="space-y-8">
        <div class="flex items-center space-x-4 mb-8">
          <div class="w-12 h-12 rounded-full bg-primary-dark text-white flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 21h10"/><path d="M12 21v-4"/><path d="M12 17c2.5 0 4.5-2 5-4.5"/><path d="M7 12.5C7.5 15 9.5 17 12 17"/><path d="M12 8v4"/><path d="M8 8a4 4 0 0 1 8 0"/><path d="M12 4v4"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-primary-dark">Para Él</h3>
        </div>
        
        <div class="space-y-6">
          {servicesHim.map(service => (
            <div class="group p-6 rounded-2xl bg-gray-50 hover:bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-transparent hover:border-gray-100">
              <h4 class="text-lg font-bold text-gray-900 mb-2">{service.name}</h4>
              <p class="text-gray-600">{service.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Her Column -->
      <div class="space-y-8">
        <div class="flex items-center space-x-4 mb-8">
          <div class="w-12 h-12 rounded-full bg-primary-light text-primary-dark ring-1 ring-primary-dark/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M14.5 4a3.5 3.5 0 0 1-5 0"/><path d="M12 13v8"/><path d="M9 17h6"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-primary-dark">Para Ella</h3>
        </div>
        
        <div class="space-y-6">
          {servicesHer.map(service => (
            <div class="group p-6 rounded-2xl bg-[#fdfaf8] hover:bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-transparent hover:border-[#f5ece6]">
              <h4 class="text-lg font-bold text-gray-900 mb-2">{service.name}</h4>
              <p class="text-gray-600">{service.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
