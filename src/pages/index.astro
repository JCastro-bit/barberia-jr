---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import WhyJR from '../components/WhyJR.astro';
import Testimonials from '../components/Testimonials.astro';
import Gallery from '../components/Gallery.astro';
import Location from '../components/Location.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
---

<Layout>
  <main class="flex-grow">
    <Hero />
    <Services />
    <WhyJR />
    <Testimonials />
    <Gallery />
    <Location />
  </main>
  
  <footer class="bg-gray-950 text-white py-12 border-t border-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold mb-4 font-heading tracking-widest">BARBERÍA JR</h2>
      <p class="text-gray-400 mb-8 max-w-md mx-auto">Experiencia y dedicación para él y para ella. Tu imagen en las mejores manos.</p>
      <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row items-center justify-between">
        <p class="text-gray-500 text-sm">© {new Date().getFullYear()} Barbería JR. Todos los derechos reservados.</p>
        <div class="mt-4 md:mt-0 flex space-x-4">
          <!-- Social links could go here -->
          <a href="#servicios" class="text-gray-400 hover:text-white transition-colors text-sm">Servicios</a>
          <a href="#galeria" class="text-gray-400 hover:text-white transition-colors text-sm">Galería</a>
          <a href="#ubicacion" class="text-gray-400 hover:text-white transition-colors text-sm">Ubicación</a>
        </div>
      </div>
    </div>
  </footer>

  <FloatingWhatsApp />
</Layout>
